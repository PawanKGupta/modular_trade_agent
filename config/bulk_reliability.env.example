# Bulk / overnight: copy into .env before `python trade_agent.py --backtest`
# Quality path unchanged (integrated backtest + full analyze_ticker). These only slow Yahoo calls.

# Required for bulk (differs from app defaults: concurrency 5, delay 1.0s)
MAX_CONCURRENT_ANALYSES=1
API_RATE_LIMIT_DELAY=2.0

# Optional — only if circuit breaker trips on long runs (defaults: threshold 3, timeout 60s)
# CIRCUITBREAKER_FAILURE_THRESHOLD=5
# CIRCUITBREAKER_RECOVERY_TIMEOUT=120

# Optional — backtest / validator / ML (defaults shown; uncomment to override)
# BULK_BACKTEST_FALLBACK_TO_SIMPLE=true   # false = no simple fallback when integrated fails
# BULK_EXPECT_INTEGRATED_BACKTEST=false   # true = validator fails on simple_fallback rows
# ML_ALLOW_BULK_ANALYSIS_TRAINING_CSV=false  # true = allow bulk_analysis_final_*.csv for admin train
