# Bulk / overnight analysis — reliability profile (Phase 0)
#
# Copy values into your project .env before:
#   python trade_agent.py --backtest
#
# Quality path is unchanged: integrated backtest + full analyze_ticker per signal.
# These settings only reduce Yahoo rate-limit failures and run contention.

# --- Rate limiting (recommended for bulk) ---
API_RATE_LIMIT_DELAY=2.0
MAX_CONCURRENT_ANALYSES=1

# --- Retries / circuit breaker (more tolerant overnight runs) ---
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=30.0
CIRCUITBREAKER_FAILURE_THRESHOLD=5
CIRCUITBREAKER_RECOVERY_TIMEOUT=120

# --- Backtest engine ---
# Integrated is used when integrated_backtest imports successfully.
# Per-symbol outcomes are logged in bulk_analysis_final_*.csv as backtest_mode:
#   integrated | simple | simple_fallback | failed
#
# Set to false to skip simple fallback when integrated fails (symbol scored as failed).
# BULK_BACKTEST_FALLBACK_TO_SIMPLE=true

# --- Optional validator strictness (tools/validate_bulk_analysis_final.py) ---
# Fail validation if any row used simple_fallback (expect full integrated path).
# BULK_EXPECT_INTEGRATED_BACKTEST=false

# --- ML training API (admin POST /api/v1/admin/ml/train) ---
# Default: reject training_data_path that looks like bulk_analysis_final_*.csv
# ML_ALLOW_BULK_ANALYSIS_TRAINING_CSV=false
