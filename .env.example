# Copy to `.env` (not committed) and set values. Never commit real secrets.
#
# Server (FastAPI) — used for Razorpay API + Standard Checkout HMAC verify.
# Optional if credentials are stored via Admin → Billing.
# Set true to ignore the RAZORPAY_* env vars and use only DB (Admin → Billing).
# RAZORPAY_USE_DB_ONLY=false
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
#
# Vite (web) — public key id only; do not put the secret here.
# Many flows return `key_id` from the API; this is an optional override for local UIs.
# VITE_RAZORPAY_KEY_ID=
#
# Auth emails (password reset, email verification) — same SMTP as trading notifications.
# FRONTEND_BASE_URL=http://localhost:5173
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-google-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_USE_TLS=true
#
# Registration — signup and profile email changes accept only approved provider domains
# (Gmail, Outlook, Yahoo, iCloud, Rediffmail, Zoho, Proton, etc.). See
# server/app/resources/email_domain_allowlist.conf for the bundled list.
# EMAIL_DOMAIN_ALLOWLIST_ENABLED=true
# Optional: allow corporate or pilot domains (comma-separated, same as CORS_ALLOW_ORIGINS)
# EMAIL_DOMAIN_ALLOWLIST_EXTRA=acmecorp.com,partner.in
#
# Auth security (production — see docs/security/USER_DATA_SECURITY.md)
# JWT_SECRET=your-strong-random-secret
# APP_DATA_ENCRYPTION_KEY=   # Fernet key for broker creds / MFA secrets
# AUTH_USE_COOKIES=true
# AUTH_COOKIE_SECURE=false     # set true behind HTTPS in production
# PASSWORD_HASH_ROUNDS=290000
# RATE_LIMIT_ENABLED=true
# MFA_REQUIRED_FOR_ADMIN=false
# MFA_REQUIRED_FOR_BROKER_MODE=false
#
# News sentiment — composite sources (see core/news_providers.py)
# NEWS_SOURCES=composite
# NEWS_SENTIMENT_LOOKBACK_DAYS=7
# NEWS_SENTIMENT_MIN_ARTICLES=2
# NEWS_SENTIMENT_BACKEND=auto
# auto = transformer on CPU when torch is installed (see requirements-sentiment.txt), else lexicon
# Default model (stricter downgrades): distilbert-base-uncased-finetuned-sst-2-english
# NEWS_SENTIMENT_TRANSFORMER_MODEL=distilbert-base-uncased-finetuned-sst-2-english
# Optional finance-tuned model (fewer false downgrades on sales/earnings headlines):
# NEWS_SENTIMENT_TRANSFORMER_MODEL=ProsusAI/finbert
# NEWS_GOOGLE_RSS_ENABLED=true
# Universe scan: cheap (no paid API). Backtest: cheap. Filtered buys: enrich with paid.
# NEWS_UNIVERSE_PROFILE=cheap
# NEWS_BACKTEST_PROFILE=cheap
# NEWS_LIVE_PROFILE=full
# NEWS_ENRICH_FILTERED_NEWS=true
# MARKETAUX_NEWS_LIMIT=3
# MARKETAUX_API_KEY=
# NEWSDATA_API_KEY=
#
# Database (Postgres recommended for production OHLCV cache)
# DB_URL=postgresql+psycopg2://trader:changeme@127.0.0.1:5432/tradeagent
#
# Daily OHLCV cache (price_cache) — see docs/guides/BULK_ANALYSIS_RELIABILITY.md
# OHLCV_CACHE_ENABLED=true
# Daily 1d source: nse (default) | yahoo | nse_with_yahoo_fallback
# Use nse_with_yahoo_fallback or yahoo until NSE backfill completes on prod.
# OHLCV_DAILY_SOURCE=nse
# NSE_BHAVCOPY_CACHE_DIR=.cache/nse_bhavcopy
# NSE_BHAVCOPY_USE_DISK_CACHE=false
# NSE_BHAVCOPY_REQUEST_DELAY_S=0.15
# NSE_BHAVCOPY_REQUEST_TIMEOUT_S=30
# Comma-separated NSE SctySrs codes for EOD equity (default includes T2T/B-group: BE, BL, BZ)
# NSE_BHAVCOPY_EQUITY_SERIES=EQ,BE,BL,BZ
# After enabling nse: .venv/bin/python tools/nse_bhavcopy_backfill.py backfill-cached --days 500
#
# Yahoo rate limit (still used for 1wk, 1m, corp actions, optional fallback)
# API_RATE_LIMIT_DELAY=1.0
