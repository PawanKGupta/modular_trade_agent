# Copy to `.env` (not committed) and set values. Never commit real secrets.
#
# Server (FastAPI) — used for Razorpay API + Standard Checkout HMAC verify.
# Optional if credentials are stored via Admin → Billing.
# Set true to ignore the RAZORPAY_* env vars and use only DB (Admin → Billing).
# RAZORPAY_USE_DB_ONLY=false
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
#
# Vite (web) — public key id only; do not put the secret here.
# Many flows return `key_id` from the API; this is an optional override for local UIs.
# VITE_RAZORPAY_KEY_ID=
#
# News sentiment — composite sources (see core/news_providers.py)
# NEWS_SOURCES=composite
# NEWS_SENTIMENT_LOOKBACK_DAYS=7
# NEWS_SENTIMENT_MIN_ARTICLES=2
# NEWS_GOOGLE_RSS_ENABLED=true
# Universe scan: cheap (no paid API). Backtest: cheap. Filtered buys: enrich with paid.
# NEWS_UNIVERSE_PROFILE=cheap
# NEWS_BACKTEST_PROFILE=cheap
# NEWS_LIVE_PROFILE=full
# NEWS_ENRICH_FILTERED_NEWS=true
# MARKETAUX_NEWS_LIMIT=3
# MARKETAUX_API_KEY=
# NEWSDATA_API_KEY=
